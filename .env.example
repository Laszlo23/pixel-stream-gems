# =============================================================================
# Gems monorepo — copy to `.env` at repo root and fill in values.
# Never commit `.env` or real private keys.
# =============================================================================
#
# Forge / Foundry loads `.env` from `packages/contracts/` when you run forge
# there. Either:
#   - maintain `packages/contracts/.env` (see packages/contracts/.env.example), or
#   - from repo root:  ln -sf ../../.env packages/contracts/.env
# Or use:  npm run forge:deploy:sepolia  (sources root `.env` before forge)
#
# After deploy: copy contract addresses into **[DEPLOYMENTS.md](DEPLOYMENTS.md)** and
# into the NEXT_PUBLIC_* vars below (and your host’s env). Never commit real keys.

# -----------------------------------------------------------------------------
# Smart contracts (Foundry) — required for `forge script ... --broadcast`
# -----------------------------------------------------------------------------
# Hex-encoded deployer private key (64 hex chars). Use a dedicated hot wallet.
# With 0x prefix is fine for forge `vm.envUint("PRIVATE_KEY")`.
PRIVATE_KEY=

# RPC URL for Base Sepolia (must match foundry.toml [rpc_endpoints] base_sepolia)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Base mainnet when deploying to production
# BASE_MAINNET_RPC_URL=https://mainnet.base.org

# --- GemsMarketplace fee recipient (defaults to deployer if empty) ---
MARKETPLACE_FEE_RECIPIENT=
MARKETPLACE_FEE_BPS=250

# --- Optional FeeVault (only deployed if FEE_ASSET is not zero address) ---
FEE_ASSET=0x0000000000000000000000000000000000000000
PLATFORM=0x0000000000000000000000000000000000000000
CREATOR=0x0000000000000000000000000000000000000000
PLATFORM_BPS=1000

# --- Optional GemsPlatformToken (set to 1 to deploy) ---
DEPLOY_PLATFORM_TOKEN=0
# Cap in wei (default in script ~1_000_000 tokens if unset)
PLATFORM_TOKEN_CAP=1000000000000000000000000

# --- Agent skill market (optional deploy: npm run forge:deploy:agent-market from repo root) ---
# AGENT_MARKET_FEE_RECIPIENT=
# AGENT_MARKET_FEE_BPS=250

# --- Basescan verification (optional; same API key from https://basescan.org/myapikey ) ---
# Required for `npm run forge:deploy:sepolia:verify` (broadcast + verify in one step).
# BASESCAN_API_KEY=
# (Optional alias; Foundry reads BASESCAN_API_KEY from foundry.toml [etherscan])
# ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# apps/web (Next.js)
# -----------------------------------------------------------------------------
# Next normally loads only files under apps/web/. This repo preloads ../../.env from
# apps/web/next.config.ts so root .env works with `npm run dev` / `npm run build -w web`.
# Optional: still symlink for tooling that only reads apps/web:
#   ln -sf ../../.env apps/web/.env.local
# -----------------------------------------------------------------------------
# Privy — auth + embedded wallets (https://dashboard.privy.io). See apps/web/PRIVY_SETUP.md
# App ID — safe in the browser (NEXT_PUBLIC_*). Leave empty to run without Privy (injected browser wallet only).
NEXT_PUBLIC_PRIVY_APP_ID=
# Set to 1 / true / yes to force local bypass even when NEXT_PUBLIC_PRIVY_APP_ID is set.
# NEXT_PUBLIC_PRIVY_DISABLED=
# Production canonical URL (no trailing slash): legal links in Privy modal + Next metadataBase
NEXT_PUBLIC_SITE_URL=
# “Built on” strip on landing + footer (marketing links)
# NEXT_PUBLIC_STACK_ZERO_G_URL=https://www.0g.ai
# NEXT_PUBLIC_STACK_BASE_URL=https://www.base.org

# Optional: comma-separated subset; must also be enabled in Privy dashboard (default: email,google,apple,wallet)
# NEXT_PUBLIC_PRIVY_LOGIN_METHODS=email,google,apple,wallet
# Optional: base-sepolia (default) or base / 8453 for default embedded-wallet chain
# NEXT_PUBLIC_PRIVY_DEFAULT_CHAIN=base-sepolia
# Optional: dedicated RPCs (Alchemy, Infura) — recommended for production
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
# NEXT_PUBLIC_BASE_MAINNET_RPC_URL=
# Optional Privy modal branding
# NEXT_PUBLIC_PRIVY_ACCENT_COLOR=#a855f7
# NEXT_PUBLIC_PRIVY_LANDING_HEADER=Welcome to Gems
# NEXT_PUBLIC_PRIVY_WALLET_FIRST=0
# Set to 1 only if CAPTCHA is enabled in the Privy dashboard
# NEXT_PUBLIC_PRIVY_CAPTCHA_ENABLED=0
# App secret — server-only for future API verification; never NEXT_PUBLIC_*
PRIVY_APP_SECRET=
# WalletConnect Cloud project ID — used by Privy for external wallets (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_API_URL=http://127.0.0.1:8788
# When live WebSocket chat is connected, still merge AI presenter lines into the panel (distinct “AI” badge).
NEXT_PUBLIC_DEMO_AI_CHAT=0
NEXT_PUBLIC_GATE_URL=http://127.0.0.1:8787
NEXT_PUBLIC_SIGNALING_WS=ws://127.0.0.1:4001
# Canonical addresses for your deployment: see [DEPLOYMENTS.md](DEPLOYMENTS.md)
NEXT_PUBLIC_CREATOR_TOKEN_FACTORY_ADDRESS=
NEXT_PUBLIC_CREATOR_NFT_FACTORY_ADDRESS=
NEXT_PUBLIC_GEMS_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_GEMS_PLATFORM_TOKEN_ADDRESS=
NEXT_PUBLIC_CREATOR_ECONOMY_REGISTRY_ADDRESS=
NEXT_PUBLIC_LP_STAKING_REWARDS_ADDRESS=
NEXT_PUBLIC_NFT_STAKING_REWARDS_ADDRESS=
NEXT_PUBLIC_CREATOR_TOKEN_ADDRESS=
NEXT_PUBLIC_FEE_VAULT_ADDRESS=
# AgentSkillMarket (Base Sepolia) — optional UI on /creator/ai + API quota when PRESENTER_REQUIRE_ASM_PURCHASE=1
# NEXT_PUBLIC_AGENT_SKILL_MARKET_ADDRESS=
# NEXT_PUBLIC_AGENT_SKILL_MARKET_AGENT_ID=0
# NEXT_PUBLIC_AGENT_SKILL_MARKET_SKILL_ID=0
# Add 0G Galileo to Privy/wagmi when set to 1
# NEXT_PUBLIC_0G_CHAIN_ENABLED=0
# Optional override for Galileo RPC in the browser (default https://evmrpc-testnet.0g.ai)
# NEXT_PUBLIC_ZG_RPC_URL=
# Superfluid money streaming (Base / Base Sepolia). Use a Super Token address (e.g. USDCx).
NEXT_PUBLIC_SUPERFLUID_SUPER_TOKEN=
NEXT_PUBLIC_DEFAULT_FLOW_RECEIVER=
# Optional: override protocol-v1 subgraph; if empty, URL is taken from @superfluid-finance/metadata (Base Sepolia has a built-in fallback).
NEXT_PUBLIC_SUPERFLUID_SUBGRAPH=
# Optional: multiply streamed token/hour for the “$ / hr” estimate (default 1). Set to 1 for stablecoins, or a spot price for other Super Tokens.
NEXT_PUBLIC_SUPERFLUID_USD_PER_TOKEN=1
NEXT_PUBLIC_SWAP_URL=
NEXT_PUBLIC_TURN_JSON=

# -----------------------------------------------------------------------------
# services/gate
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
RPC_URL=https://sepolia.base.org
GATE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
GATE_MIN_TOKEN_BALANCE=0
SUPERFLUID_SUBGRAPH_URL=
FLOW_CHECK_RECEIVER=
FLOW_CHECK_TOKEN=

# -----------------------------------------------------------------------------
# services/api
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:pass@localhost:5432/gems
# Comma-separated; default in code includes localhost + 127.0.0.1 for Next dev
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# xAI Grok — server-only; used by POST /v1/rooms/:roomId/presenter-reply when PRESENTER_LLM=xai or auto (fallback)
XAI_API_KEY=
XAI_MODEL=grok-2-latest
# Presenter LLM: auto | zerog | xai (default auto: prefer 0G if ZG_* set, else xAI)
# PRESENTER_LLM=auto

# --- 0G Compute (tokenized inference) — server-only; never NEXT_PUBLIC_*
# Galileo testnet RPC: https://evmrpc-testnet.0g.ai
ZG_RPC_URL=
# Hex private key of hot wallet on 0G chain (fund + ledger.depositFund per 0G docs)
ZG_WALLET_PRIVATE_KEY=
# Optional inference provider address; if unset, first on-chain chatbot service is used
# ZG_DEFAULT_PROVIDER_ADDRESS=
# Fund native 0G on Galileo, then deposit into compute ledger (local CLI — never share keys):
#   npm run zg:ledger -w api -- status
#   npm run zg:ledger -w api -- deposit 0.05
# After funding, record the **public** wallet address and deposit tx in [DEPLOYMENTS.md](DEPLOYMENTS.md).

# --- Optional: require AgentSkillMarket purchase before presenter LLM (Base / Base Sepolia)
# PRESENTER_REQUIRE_ASM_PURCHASE=1
# AGENT_SKILL_MARKET_ADDRESS=
# AGENT_SKILL_MARKET_AGENT_ID=0
# AGENT_SKILL_MARKET_SKILL_ID=0
# Reads purchases() via BASE_SEPOLIA_RPC_URL or RPC_URL from services/gate

# -----------------------------------------------------------------------------
# services/signaling (optional overrides)
# -----------------------------------------------------------------------------
# PORT=4001
