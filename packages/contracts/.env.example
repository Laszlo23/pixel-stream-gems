# Foundry auto-loads `.env` from this directory (`packages/contracts/`).
# Copy:  cp .env.example .env
# Do not commit `.env`.
#
# You can symlink the repo-root `.env` instead:
#   ln -sf ../../.env .env
#
# From repo root, prefer: `npm run forge:deploy:sepolia` (loads ../../.env).
# Record deployed addresses in ../../DEPLOYMENTS.md.

PRIVATE_KEY=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan contract verification (https://basescan.org/myapikey — works for Base Sepolia)
BASESCAN_API_KEY=

MARKETPLACE_FEE_RECIPIENT=
MARKETPLACE_FEE_BPS=250

FEE_ASSET=0x0000000000000000000000000000000000000000
PLATFORM=0x0000000000000000000000000000000000000000
CREATOR=0x0000000000000000000000000000000000000000
PLATFORM_BPS=1000

DEPLOY_PLATFORM_TOKEN=0
PLATFORM_TOKEN_CAP=1000000000000000000000000

AGENT_MARKET_FEE_RECIPIENT=
AGENT_MARKET_FEE_BPS=250

